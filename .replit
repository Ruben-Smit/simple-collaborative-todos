modules = ["svelte-kit-node-20:v1-20230724-46059dd", "nodejs-20:v10-20231103-2b03dda"]
run = "vite dev --host 0.0.0.0"

[nix]
channel = "stable-22_11"

[deployment]
build = ["npm", "run", "build"]
run = ["node", "build"]
deploymentTarget = "gce"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5173
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx vite dev --host 0.0.0.0 --port 5000 --strictPort"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
